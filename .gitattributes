# Force LF line endings on shell scripts and config files that run on Linux.
*.sh        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf
Dockerfile  text eol=lf

# Python stays with platform default (works fine either way):
*.py        text

# JSON and markdown stay text, Git normaliza conforme plataforma:
*.json      text
*.md        text
